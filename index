<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Product Image Generator</title>
  <script src="https://html2canvas.hertzen.com/dist/html2canvas.min.js"></script>

  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f5f5f5;
      padding: 40px;
    }

    /* This controls how big the final image is */
    #productCard {
      width: 900px;
      background: white;
      border-radius: 24px;
      padding: 60px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    }

    #productName {
      font-size: 56px;
      margin-bottom: 30px;
    }

    #productPrice {
      font-size: 48px;
      color: #e60023;
      font-weight: bold;
      margin-bottom: 30px;
    }

    #productLink {
      font-size: 28px;
      color: #0066ff;
      word-break: break-all;
    }

    .controls {
      margin-bottom: 40px;
    }

    input {
      display: block;
      width: 900px;
      padding: 18px;
      font-size: 22px;
      margin-bottom: 20px;
    }

    button {
      font-size: 24px;
      padding: 16px 40px;
      border-radius: 12px;
      border: none;
      background: #000;
      color: white;
      cursor: pointer;
    }
  </style>
</head>
<body>

  <div class="controls">
    <input id="nameInput" placeholder="Product name">
    <input id="priceInput" placeholder="Price (e.g. $19.99)">
    <input id="linkInput" placeholder="Product link">
    <button onclick="updateCard()">Update Card</button>
    <button onclick="downloadImage()">Download Image</button>
  </div>

  <div id="productCard">
    <div id="productName">Product Name</div>
    <div id="productPrice">$0.00</div>
    <div id="productLink">https://example.com</div>
  </div>

  <script>
    function updateCard() {
      document.getElementById("productName").innerText =
        document.getElementById("nameInput").value || "Product Name";

      document.getElementById("productPrice").innerText =
        document.getElementById("priceInput").value || "$0.00";

      document.getElementById("productLink").innerText =
        document.getElementById("linkInput").value || "https://example.com";
    }

    function downloadImage() {
      html2canvas(document.getElementById("productCard"), {
        scale: 2  // boosts resolution even more
      }).then(canvas => {
        const link = document.createElement("a");
        link.download = "product.png";
        link.href = canvas.toDataURL("image/png");
        link.click();
      });
    }
  </script>

</body>
</html>
